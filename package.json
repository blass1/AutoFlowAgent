{
  "name": "autoflow",
  "version": "0.1.0",
  "private": true,
  "description": "Agente de automatización para QAs",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "record": "node .autoflow/scripts/start-recording.js",
    "run:test": "node .autoflow/scripts/run-test.js",
    "run:set": "node .autoflow/scripts/run-testset.js",
    "dashboard": "node .autoflow/scripts/dashboard.js --open",
    "audit": "node .autoflow/scripts/validar-coherencia.js && node .autoflow/scripts/validar-trazas.js --solo-audit"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "xlsx": "^0.18.5"
  }
}
