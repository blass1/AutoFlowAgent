node_modules/
dist/
build/
.DS_Store
*.log
.env
.env.local

# Playwright
playwright-report/
test-results/
blob-report/

# AutoFlow runs: carpeta por corrida con artifacts (screenshots, traces, videos).
# Formato DD_MM_YYYY_HH-MM-SS, lo crean run-test.js / run-testset.js antes de
# invocar Playwright vía AUTOFLOW_RUN_DIR (ver playwright.config.ts).
runs/

# Specs temporales generados por el agente (page.pause(), prueba de auth, etc.)
tests/_temp/

# AutoFlow runtime
.autoflow/user.json
.autoflow/recordings/*
!.autoflow/recordings/.gitkeep
.autoflow/auth/*.json
!.autoflow/auth/.gitkeep
.autoflow/alm-exports/*.xlsx
.autoflow/alm-exports/*.csv
.autoflow/alm-exports/*.json
!.autoflow/alm-exports/.gitkeep
.autoflow/alm/integrations/*.exe
!.autoflow/alm/integrations/.gitkeep
.autoflow/alm/originalTests/*.json
!.autoflow/alm/originalTests/.gitkeep
.autoflow/alm/exports/*.json
.autoflow/alm/exports/*.xlsx
!.autoflow/alm/exports/.gitkeep
.autoflow/runs/*.json
!.autoflow/runs/.gitkeep
.autoflow/dashboard.html

# VSCode (mantenemos solo tasks.json versionado)
.vscode/*
!.vscode/tasks.json

# Claude Code (config local del dev, no se versiona)
.claude/

# Docs / presentaciones (no se versionan por ahora)
docs/
